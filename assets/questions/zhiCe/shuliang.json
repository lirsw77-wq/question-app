      "type": "single_choice",
      "options": ["A. 53", "B. 68", "C. 83", "D. 98"],
      "answer": "A",
      "explanation": "用中国剩余定理或逐个验证：53÷3=17余2，53÷5=10余3，53÷7=7余4，满足所有条件。",
      "difficulty": 4,
      "knowledge_points": ["余数问题"]
    },
