    {
      "content": "某商品原价200元，先涨价20%，再降价20%，现价是多少元？",
      "type": "single_choice",
      "options": ["A. 192元", "B. 200元", "C. 208元", "D. 196元"],
      "answer": "A",
      "explanation": "200×(1+20%)×(1-20%) = 200×1.2×0.8 = 192元。",
      "difficulty": 2,
      "knowledge_points": ["百分比"]
    },
    {
      "content": "甲、乙两人从相距100公里的两地同时出发相向而行，甲每小时走6公里，乙每小时走4公里，几小时后两人相遇？",
      "type": "single_choice",
      "options": ["A. 8小时", "B. 10小时", "C. 12小时", "D. 15小时"],
      "answer": "B",
      "explanation": "相遇时间 = 距离 ÷ 速度和 = 100 ÷ (6+4) = 10小时。",
      "difficulty": 2,
      "knowledge_points": ["行程问题"]
    },
